; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Raven Hollow"
config/description="Raven Hollow — a dark medieval pixel RPG set in the world of Draconia"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]
LootSystem="*res://scripts/systems/loot_system.gd"

VoiceRegistry="*res://scripts/voice_registry.gd"
Voice="*res://scripts/voice_client.gd"
TravelSystem="*res://scripts/travel_system.gd"

[debug]

gdscript/warnings/treat_warnings_as_errors=false

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=1920
window/size/window_height_override=1080
window/stretch/mode="canvas_items"
window/stretch/scale_mode="integer"

