{
  "_doc": "Raven Hollow crafting DB (BACKLOG #42, design/CRAFTING.md). Consumed by CraftingSystem (scripts/systems/crafting_system.gd). Seven Draconia primary professions, WoW-Classic structure with a raised skill cap of 1000. professions = the craft roster + home station + trainer; materials = reagent DB (icon resolves through IconsPixel as 'pixel:<icon>'); recipes = materials -> output item (LootSystem/Inventory item shape). unlock: trainer recipes are auto-known when the profession is learned (still gated by skill_req); fragment/master/festival/vendor/legendary/boss recipes must be learned (learn_recipe) from the world. Each profession carries one legendary recipe; boss-drop legendaries (boss_drop:true) are class-flavored per owner amendment.",
  "config": {
    "max_skill": 1000,
    "ranks": {"1": "Hand", "150": "Sworn", "375": "Master", "650": "Keeper"},
    "ink_bands": {"wet": 40, "settled": 80, "fading": 120}
  },

  "professions": {
    "bog_iron": {
      "id": "bog_iron", "name": "Bog-Iron Smelting", "kind": "primary",
      "station": "forge", "field_gather": "pan_shallows", "trainer": "blacksmith",
      "flavor": "River-smelted. Ugly work, honest metal. The only craft the Stone cannot subvert, because it never meant anything but nails."
    },
    "blackglass": {
      "id": "blackglass", "name": "Blackglass Working", "kind": "primary",
      "station": "knapping_bench", "field_gather": "knap_the_seam", "trainer": "cw_tinker",
      "flavor": "Flint before glass, dear. Blackglass takes an edge once - it has never needed a second."
    },
    "thread_binding": {
      "id": "thread_binding", "name": "Thread-Binding", "kind": "primary",
      "station": "binding_post", "field_gather": "wind_a_loose_end", "trainer": "bn_threadtender",
      "flavor": "Filament is Iele state property. Every legal gram comes with paperwork; every illegal gram comes with a story."
    },
    "ledger_craft": {
      "id": "ledger_craft", "name": "Ledger-Scribing", "kind": "primary",
      "station": "scribe_desk", "field_gather": "copy_the_board", "trainer": "aw_lera",
      "flavor": "Information turned into consumables. A dossier is a buff; a cipher is immunity to being listened to."
    },
    "folk_warding": {
      "id": "folk_warding", "name": "Folk-Warding", "kind": "primary",
      "station": "hearth", "field_gather": "gather_the_hedge", "trainer": "vk_marta",
      "flavor": "It means nothing. That is the whole defense. Protection that works BECAUSE it refuses to mean anything."
    },
    "lichen_culture": {
      "id": "lichen_culture", "name": "Lichen-Culturing", "kind": "primary",
      "station": "culture_trough", "field_gather": "scrape_the_bed", "trainer": "cw_circuit",
      "flavor": "Grow light instead of burning it. Beds must be cultured in true dark; the brightest strains grow on things best not asked about."
    },
    "hessik_method": {
      "id": "hessik_method", "name": "Hessik-Method Brewing", "kind": "primary",
      "station": "still", "field_gather": "draw_a_sample", "trainer": "iv_zorka",
      "flavor": "Not potion-spam: reading the land. The one person in the party who knows which well is clean."
    }
  },

