{
  "_doc": "Dynamic Music Director data (BACKLOG #53, design/SCORE_BIBLE.md). Per-zone/region/biome exploration beds, a global state set (explore/tension/combat/boss/victory/town/night), stingers, and equal-power crossfade times. Track values are LOGICAL paths -- the real .ogg stems are authored later (SCORE_BIBLE section 8); MusicSystem stays silent + guarded when a file is absent.",

  "default_volume_db": -14.0,

  "crossfades": {
    "explore": 3.0,
    "tension": 1.5,
    "combat": 0.8,
    "boss": 1.2,
    "victory": 1.0,
    "town": 2.5,
    "night": 2.0,
    "default": 1.5
  },

  "states": {
    "explore": { "track": "res://assets/audio/music/state_explore.ogg", "volume_db": -14.0, "loop": true },
