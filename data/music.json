    "combat":  { "track": "res://assets/audio/music/state_combat.ogg",  "volume_db": -11.0, "loop": true },
    "boss":    { "track": "res://assets/audio/music/state_boss.ogg",    "volume_db": -10.0, "loop": true },
    "victory": { "track": "res://assets/audio/music/state_victory.ogg", "volume_db": -11.0, "loop": false, "hold": 6.0 },
    "town":    { "track": "res://assets/audio/music/state_town.ogg",    "volume_db": -15.0, "loop": true },
    "night":   { "track": "res://assets/audio/music/state_night.ogg",   "volume_db": -16.0, "loop": true }
  },

  "start_state": "explore",

